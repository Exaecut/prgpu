{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:CUDA_PATH}\\include",
                "${env:CUDA_PATH}\\include\\**"
            ],
            "defines": [
                "__CUDACC__"
            ],
            "compilerPath": "${env:CUDA_PATH}/bin/nvcc.exe",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/**",
                    "${env:CUDA_PATH}/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}