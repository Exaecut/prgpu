{
    "configurations": [
        {
            "type": "cppvsdbg",
            "request": "launch",
            "name": "Premiere Pro (Windows)",
            "program": "${env:PROGRAMFILES}/Adobe/Adobe Premiere Pro 2025/Adobe Premiere Pro.exe",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "symbolSearchPath": "${workspaceFolder}/target/debug",
            "console": "integratedTerminal",
            "logging": {
                "moduleLoad": true
            },
            "preLaunchTask": "Build"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Premiere Pro (macOS)",
            "program": "/Applications/Adobe Premiere Pro 2025/Adobe Premiere Pro 2025.app/Contents/MacOS/Adobe Premiere Pro 2025",
            "args": [],
            "env": {
                "RUST_BACKTRACE": "1",
                "MTL_DEBUG_LAYER": "1"
            },
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build",
            "terminal": "console",
            "stdio": [
                null,
                "console",
                "console"
            ]
        },
        {
            "type": "cppvsdbg",
            "request": "launch",
            "name": "After Effects (Windows)",
            "program": "${env:PROGRAMFILES}/Adobe/Adobe After Effects 2025/Support Files/AfterFX.exe",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "symbolSearchPath": "${workspaceFolder}/target/debug",
            "console": "integratedTerminal",
            "logging": {
                "moduleLoad": true
            },
            "preLaunchTask": "Build"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "After Effects (macOS)",
            "program": "/Applications/Adobe After Effects 2025/Adobe After Effects 2025.app/Contents/MacOS/After Effects",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build",
            "terminal": "console",
            "stdio": [
                null,
                "console",
                "console"
            ]
        }
    ]
}