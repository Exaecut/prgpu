{
    "configurations": [
        {
            "name": "CUDA",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:CUDA_PATH}\\include",
                "${env:CUDA_PATH}\\include\\**"
            ],
            "defines": [
                "__CUDACC__"
            ],
            "compilerPath": "${env:CUDA_PATH}/bin/nvcc.exe",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/**",
                    "${env:CUDA_PATH}/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "Metal",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:PROGRAM_FILES}/Metal Developer Tools/metal/32023/lib/clang/32023.830/include/metal"
            ],
            "defines": [
                "__METAL_VERSION__=200"
            ],
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}